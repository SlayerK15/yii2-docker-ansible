services:
  app:
    image: slayerop15/yii2-app:latest
    networks:
      - yii2network
    volumes:
      - "{{ app_dir }}/runtime:/app/runtime"
      - "{{ app_dir }}/web/assets:/app/web/assets"
    environment:
      - YII_ENV={{ yii_env | default('dev') }}
      - YII_DEBUG={{ yii_debug | default('true') }}
      - DB_HOST=db
      - DB_DATABASE={{ db_name }}
      - DB_USERNAME={{ db_user }}
      - DB_PASSWORD={{ db_password }}
    ports:
      - "9000:9000"  # Expose PHP-FPM port for host Nginx
    deploy:
      replicas: 1
      restart_policy:
        condition: on-failure
        max_attempts: 3
      update_config:
        parallelism: 1
        delay: 10s
        order: start-first
      resources:
        limits:
          memory: 512M
          
  db:
    image: mysql:8.0
    networks:
      - yii2network
    volumes:
      - "{{ app_dir }}/data/mysql:/var/lib/mysql"
    environment:
      - MYSQL_ROOT_PASSWORD={{ db_root_password }}
      - MYSQL_DATABASE={{ db_name }}
      - MYSQL_USER={{ db_user }}
      - MYSQL_PASSWORD={{ db_password }}
    deploy:
      replicas: 1
      restart_policy:
        condition: on-failure
        max_attempts: 3
      resources:
        limits:
          memory: 512M

networks:
  yii2network:
    driver: overlay 
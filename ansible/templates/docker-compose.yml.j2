services:
  app:
    image: slayerop15/yii2-app:latest
    networks:
      - yii2network
    volumes:
      - "${APP_DIR}/runtime:/app/runtime"
      - "${APP_DIR}/web/assets:/app/web/assets"
    environment:
      - YII_ENV={{ yii_env | default('dev') }}
      - YII_DEBUG={{ yii_debug | default('true') }}
      - DB_HOST=db
      - DB_DATABASE={{ db_name }}
      - DB_USERNAME={{ db_user }}
      - DB_PASSWORD={{ db_password }}
    deploy:
      replicas: 1
      restart_policy:
        condition: on-failure
        max_attempts: 3
      update_config:
        parallelism: 1
        delay: 10s
        order: start-first
      resources:
        limits:
          memory: 512M
          
  db:
    image: mysql:8.0
    networks:
      - yii2network
    volumes:
      - "${APP_DIR}/data/mysql:/var/lib/mysql"
    environment:
      - MYSQL_ROOT_PASSWORD={{ db_root_password }}
      - MYSQL_DATABASE={{ db_name }}
      - MYSQL_USER={{ db_user }}
      - MYSQL_PASSWORD={{ db_password }}
    deploy:
      replicas: 1
      restart_policy:
        condition: on-failure
        max_attempts: 3
      resources:
        limits:
          memory: 512M

  nginx:
    image: nginx:1.21
    networks:
      - yii2network
    volumes:
      - "${APP_DIR}/nginx/default.conf:/etc/nginx/conf.d/default.conf:ro"
    depends_on:
      - app
    ports:
      - "80:80"
    deploy:
      replicas: 1
      restart_policy:
        condition: on-failure
        max_attempts: 3
      resources:
        limits:
          memory: 128M

networks:
  yii2network:
    driver: overlay 